# Copy this file to ${user.home}/.bms/application-local.properties.
# Keep the copied file outside this Git repository.
spring.datasource.url=jdbc:postgresql://localhost:15432/YOUR_DATABASE
spring.datasource.username=YOUR_USERNAME
spring.datasource.password=YOUR_PASSWORD

# Flyway 전용 접속
spring.flyway.url=jdbc:postgresql://localhost:15432/YOUR_DATABASE
spring.flyway.user=YOUR_MIGRATION_USERNAME
spring.flyway.password=YOUR_MIGRATION_PASSWORD

# 운영에서는 32바이트 이상의 별도 비밀값을 BMS_LOGIN_ID_HMAC_KEY로 주입한다.
# 로컬에서 생략하면 애플리케이션 실행 동안만 유지되는 임시 키를 사용한다.
# bms.security.login-id-hmac-key=YOUR_LOCAL_DEVELOPMENT_SECRET_AT_LEAST_32_BYTES

# 로컬 HTTP 개발에서는 false로 유지한다. 운영 prod 프로필은 true가 아니면 기동에 실패한다.
server.servlet.session.cookie.secure=false

# 기본값은 비어 있으며 X-Forwarded-For를 신뢰하지 않는다.
# 리버스 프록시를 사용하는 환경에서 승인된 프록시 CIDR만 쉼표로 구분해 설정한다.
# bms.web.trusted-proxies=10.0.0.0/8,192.168.0.0/16
